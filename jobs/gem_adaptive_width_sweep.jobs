# GEM adaptive width — full base-model sweep
#
# Validates near-final rule (HL/N > 0.85 → w=1) across all 25 base models.
# Gemma-2-2b and OPT-6.7b already done; script skips them automatically.
#
# Runs from ~/rosetta_data so RESULTS_ROOT resolves to existing GEM data.
# Script pulled fresh from ~/rosetta_analysis before each family batch.
#
# Ordered small-to-large within families; barrier between families to avoid
# hammering HF with back-to-back large-model downloads.
#
# Setup: ensure rosetta_data exists, clone rosetta_analysis if needed, then run pythia-70m
cd ~ && mkdir -p ~/rosetta_data && [ -d rosetta_analysis ] || git clone git@github.com:jamesrahenry/Rosetta_Analysis.git rosetta_analysis && git -C ~/rosetta_analysis pull && cd ~/rosetta_data && python ~/rosetta_analysis/gem/ablate_gem_adaptive_width.py --model EleutherAI/pythia-70m
# Pythia-160m
cd ~/rosetta_data && git -C ~/rosetta_analysis pull && python ~/rosetta_analysis/gem/ablate_gem_adaptive_width.py --model EleutherAI/pythia-160m
# Pythia-410m
cd ~/rosetta_data && python ~/rosetta_analysis/gem/ablate_gem_adaptive_width.py --model EleutherAI/pythia-410m
# Pythia-1b
cd ~/rosetta_data && python ~/rosetta_analysis/gem/ablate_gem_adaptive_width.py --model EleutherAI/pythia-1b
# Pythia-1.4b
cd ~/rosetta_data && python ~/rosetta_analysis/gem/ablate_gem_adaptive_width.py --model EleutherAI/pythia-1.4b
# Pythia-2.8b
cd ~/rosetta_data && python ~/rosetta_analysis/gem/ablate_gem_adaptive_width.py --model EleutherAI/pythia-2.8b
# Pythia-6.9b
cd ~/rosetta_data && python ~/rosetta_analysis/gem/ablate_gem_adaptive_width.py --model EleutherAI/pythia-6.9b
# ---
# GPT-2 family (tiny, fast — all 4 in one barrier group)
cd ~/rosetta_data && git -C ~/rosetta_analysis pull && python ~/rosetta_analysis/gem/ablate_gem_adaptive_width.py --model openai-community/gpt2
# GPT-2-medium
cd ~/rosetta_data && python ~/rosetta_analysis/gem/ablate_gem_adaptive_width.py --model openai-community/gpt2-medium
# GPT-2-large
cd ~/rosetta_data && python ~/rosetta_analysis/gem/ablate_gem_adaptive_width.py --model openai-community/gpt2-large
# GPT-2-XL
cd ~/rosetta_data && python ~/rosetta_analysis/gem/ablate_gem_adaptive_width.py --model openai-community/gpt2-xl
# ---
# OPT family (already have 6.7b — skip is automatic)
cd ~/rosetta_data && git -C ~/rosetta_analysis pull && python ~/rosetta_analysis/gem/ablate_gem_adaptive_width.py --model facebook/opt-125m
# OPT-1.3b
cd ~/rosetta_data && python ~/rosetta_analysis/gem/ablate_gem_adaptive_width.py --model facebook/opt-1.3b
# OPT-2.7b
cd ~/rosetta_data && python ~/rosetta_analysis/gem/ablate_gem_adaptive_width.py --model facebook/opt-2.7b
# OPT-6.7b (will skip — already done)
cd ~/rosetta_data && python ~/rosetta_analysis/gem/ablate_gem_adaptive_width.py --model facebook/opt-6.7b
# ---
# Qwen family
cd ~/rosetta_data && git -C ~/rosetta_analysis pull && python ~/rosetta_analysis/gem/ablate_gem_adaptive_width.py --model Qwen/Qwen2.5-0.5B
# Qwen-1.5B
cd ~/rosetta_data && python ~/rosetta_analysis/gem/ablate_gem_adaptive_width.py --model Qwen/Qwen2.5-1.5B
# Qwen-3B
cd ~/rosetta_data && python ~/rosetta_analysis/gem/ablate_gem_adaptive_width.py --model Qwen/Qwen2.5-3B
# Qwen-7B
cd ~/rosetta_data && python ~/rosetta_analysis/gem/ablate_gem_adaptive_width.py --model Qwen/Qwen2.5-7B
# ---
# Llama, Phi, Mistral (larger models — one per barrier)
cd ~/rosetta_data && git -C ~/rosetta_analysis pull && python ~/rosetta_analysis/gem/ablate_gem_adaptive_width.py --model meta-llama/Llama-3.2-1B
# Llama-3.2-3B
cd ~/rosetta_data && python ~/rosetta_analysis/gem/ablate_gem_adaptive_width.py --model meta-llama/Llama-3.2-3B
# ---
# Phi-2
cd ~/rosetta_data && git -C ~/rosetta_analysis pull && python ~/rosetta_analysis/gem/ablate_gem_adaptive_width.py --model microsoft/phi-2
# ---
# Mistral-7B (largest in sweep — last)
cd ~/rosetta_data && git -C ~/rosetta_analysis pull && python ~/rosetta_analysis/gem/ablate_gem_adaptive_width.py --model mistralai/Mistral-7B-v0.3
# ---
# Gemma-2-2b (will skip — already done) and Gemma-2-9b (~18GB, runs last)
cd ~/rosetta_data && git -C ~/rosetta_analysis pull && python ~/rosetta_analysis/gem/ablate_gem_adaptive_width.py --model google/gemma-2-2b
# Gemma-2-9b
cd ~/rosetta_data && python ~/rosetta_analysis/gem/ablate_gem_adaptive_width.py --model google/gemma-2-9b
# ---
# Aggregate all results
cd ~/rosetta_data && git -C ~/rosetta_analysis pull && python ~/rosetta_analysis/gem/ablate_gem_adaptive_width.py --aggregate-only
