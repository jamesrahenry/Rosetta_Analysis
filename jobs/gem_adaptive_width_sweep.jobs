# GEM adaptive width — full pipeline sweep (extract → build_gems → ablate)
#
# Validates near-final rule (HL/N > 0.85 → w=1) across enabled base models.
# Each job runs all three stages for one model: extract activations, build GEMs,
# then run adaptive-width ablation. All output paths are absolute (~/rosetta_data).
#
# Model set: enabled=true, gated=false, quantization=null, no instruct tag
#   Scale:     pythia-70m, pythia-410m, pythia-2.8b, Qwen2.5-0.5B, Qwen2.5-1.5B
#   Cluster A: gpt2, pythia-160m
#   Cluster B: pythia-1b, Qwen2.5-3B
#   Cluster C: pythia-6.9b, opt-6.7b, Mistral-7B-v0.3
#   Cluster D: Qwen2.5-7B, gemma-2-9b
#   Cluster E: pythia-12b, Qwen2.5-14B  (device_map=auto, 2x L4)
#
# Ordered small-to-large within groups; barriers between groups to avoid
# hammering HF with concurrent large-model downloads.
#
# Setup — pull all required repos; barrier ensures model jobs start only after this.
git -C ~/rosetta_analysis pull && git -C ~/Rosetta_Concept_Pairs pull
# ---
# Scale ladder — pythia-70m
python ~/rosetta_analysis/extraction/extract.py --model EleutherAI/pythia-70m && python ~/rosetta_analysis/gem/build_gems.py --model EleutherAI/pythia-70m && python ~/rosetta_analysis/gem/ablate_gem_adaptive_width.py --model EleutherAI/pythia-70m
# Scale ladder — pythia-410m
python ~/rosetta_analysis/extraction/extract.py --model EleutherAI/pythia-410m && python ~/rosetta_analysis/gem/build_gems.py --model EleutherAI/pythia-410m && python ~/rosetta_analysis/gem/ablate_gem_adaptive_width.py --model EleutherAI/pythia-410m
# Scale ladder — pythia-2.8b
python ~/rosetta_analysis/extraction/extract.py --model EleutherAI/pythia-2.8b && python ~/rosetta_analysis/gem/build_gems.py --model EleutherAI/pythia-2.8b && python ~/rosetta_analysis/gem/ablate_gem_adaptive_width.py --model EleutherAI/pythia-2.8b
# Scale ladder — Qwen2.5-0.5B
python ~/rosetta_analysis/extraction/extract.py --model Qwen/Qwen2.5-0.5B && python ~/rosetta_analysis/gem/build_gems.py --model Qwen/Qwen2.5-0.5B && python ~/rosetta_analysis/gem/ablate_gem_adaptive_width.py --model Qwen/Qwen2.5-0.5B
# Scale ladder — Qwen2.5-1.5B
python ~/rosetta_analysis/extraction/extract.py --model Qwen/Qwen2.5-1.5B && python ~/rosetta_analysis/gem/build_gems.py --model Qwen/Qwen2.5-1.5B && python ~/rosetta_analysis/gem/ablate_gem_adaptive_width.py --model Qwen/Qwen2.5-1.5B
# ---
# Cluster A — gpt2
git -C ~/rosetta_analysis pull && python ~/rosetta_analysis/extraction/extract.py --model openai-community/gpt2 && python ~/rosetta_analysis/gem/build_gems.py --model openai-community/gpt2 && python ~/rosetta_analysis/gem/ablate_gem_adaptive_width.py --model openai-community/gpt2
# Cluster A — pythia-160m
python ~/rosetta_analysis/extraction/extract.py --model EleutherAI/pythia-160m && python ~/rosetta_analysis/gem/build_gems.py --model EleutherAI/pythia-160m && python ~/rosetta_analysis/gem/ablate_gem_adaptive_width.py --model EleutherAI/pythia-160m
# ---
# Cluster B — pythia-1b
git -C ~/rosetta_analysis pull && python ~/rosetta_analysis/extraction/extract.py --model EleutherAI/pythia-1b && python ~/rosetta_analysis/gem/build_gems.py --model EleutherAI/pythia-1b && python ~/rosetta_analysis/gem/ablate_gem_adaptive_width.py --model EleutherAI/pythia-1b
# Cluster B — Qwen2.5-3B
python ~/rosetta_analysis/extraction/extract.py --model Qwen/Qwen2.5-3B && python ~/rosetta_analysis/gem/build_gems.py --model Qwen/Qwen2.5-3B && python ~/rosetta_analysis/gem/ablate_gem_adaptive_width.py --model Qwen/Qwen2.5-3B
# ---
# Cluster C — pythia-6.9b (--batch-size 4: 12.4GB model, limited activation headroom)
git -C ~/rosetta_analysis pull && python ~/rosetta_analysis/extraction/extract.py --model EleutherAI/pythia-6.9b --batch-size 4 && python ~/rosetta_analysis/gem/build_gems.py --model EleutherAI/pythia-6.9b && python ~/rosetta_analysis/gem/ablate_gem_adaptive_width.py --model EleutherAI/pythia-6.9b
# Cluster C — opt-6.7b (--batch-size 4: same VRAM tier as pythia-6.9b)
python ~/rosetta_analysis/extraction/extract.py --model facebook/opt-6.7b --batch-size 4 && python ~/rosetta_analysis/gem/build_gems.py --model facebook/opt-6.7b && python ~/rosetta_analysis/gem/ablate_gem_adaptive_width.py --model facebook/opt-6.7b
# Cluster C — Mistral-7B-v0.3 (--batch-size 4)
python ~/rosetta_analysis/extraction/extract.py --model mistralai/Mistral-7B-v0.3 --batch-size 4 && python ~/rosetta_analysis/gem/build_gems.py --model mistralai/Mistral-7B-v0.3 && python ~/rosetta_analysis/gem/ablate_gem_adaptive_width.py --model mistralai/Mistral-7B-v0.3
# ---
# Cluster D — Qwen2.5-7B (--batch-size 4: 14.5GB model)
git -C ~/rosetta_analysis pull && python ~/rosetta_analysis/extraction/extract.py --model Qwen/Qwen2.5-7B --batch-size 4 && python ~/rosetta_analysis/gem/build_gems.py --model Qwen/Qwen2.5-7B && python ~/rosetta_analysis/gem/ablate_gem_adaptive_width.py --model Qwen/Qwen2.5-7B
# Cluster D — gemma-2-9b (--batch-size 1: 18.5GB model, barely fits single L4)
python ~/rosetta_analysis/extraction/extract.py --model google/gemma-2-9b --batch-size 1 && python ~/rosetta_analysis/gem/build_gems.py --model google/gemma-2-9b && python ~/rosetta_analysis/gem/ablate_gem_adaptive_width.py --model google/gemma-2-9b --batch-size 1
# ---
# Cluster E — pythia-12b (--batch-size 2, device_map=auto, 2x L4)
git -C ~/rosetta_analysis pull && python ~/rosetta_analysis/extraction/extract.py --model EleutherAI/pythia-12b --batch-size 2 && python ~/rosetta_analysis/gem/build_gems.py --model EleutherAI/pythia-12b && python ~/rosetta_analysis/gem/ablate_gem_adaptive_width.py --model EleutherAI/pythia-12b
# Cluster E — Qwen2.5-14B (--batch-size 2, device_map=auto, 2x L4)
python ~/rosetta_analysis/extraction/extract.py --model Qwen/Qwen2.5-14B --batch-size 2 && python ~/rosetta_analysis/gem/build_gems.py --model Qwen/Qwen2.5-14B && python ~/rosetta_analysis/gem/ablate_gem_adaptive_width.py --model Qwen/Qwen2.5-14B
# ---
# Aggregate all per-model results
git -C ~/rosetta_analysis pull && python ~/rosetta_analysis/gem/ablate_gem_adaptive_width.py --aggregate-only
